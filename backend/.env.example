# ── API Security ──────────────────────────────────────────────────────────────
# Auto-generated by run.sh on first run. Do not share this key.
SHAKTIDB_API_KEY=change_me_to_a_random_64_char_hex_string

# ── CORS (comma-separated allowed frontend origins) ────────────────────────────
CORS_ORIGINS=http://localhost:12001,http://localhost:5173,http://localhost:3000

# ── Storage paths ─────────────────────────────────────────────────────────────
INDEX_DIR=./faiss_indexes
CONFIGS_DIR=./configs

# ── Embedding model ───────────────────────────────────────────────────────────
MODEL_NAME=BAAI/bge-m3
EMBEDDING_DIM=1024

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=12000
RELOAD=false
